# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
SEMRUSH_API_KEY=
MANUS_API_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
# Development: https://ais-dev-fyuvmcb7wzz2bk75p4gm6r-195515573175.europe-west3.run.app
# Shared: https://ais-pre-fyuvmcb7wzz2bk75p4gm6r-195515573175.europe-west3.run.app
APP_URL="https://ais-dev-fyuvmcb7wzz2bk75p4gm6r-195515573175.europe-west3.run.app"

# META ADS CONFIGURATION
# 1. Create a "Business" or "Consumer" app at https://developers.facebook.com/
# 2. Add "Facebook Login for Business" or "Facebook Login" product.
# 3. Add Valid OAuth Redirect URI:
#    - https://ais-dev-fyuvmcb7wzz2bk75p4gm6r-195515573175.europe-west3.run.app/api/auth/callback/meta
#    - https://ais-pre-fyuvmcb7wzz2bk75p4gm6r-195515573175.europe-west3.run.app/api/auth/callback/meta
# 4. Use your App ID (usually a long number) as META_CLIENT_ID.
# 5. Use your App Secret as META_CLIENT_SECRET.
META_APP_ID=
META_APP_SECRET=
META_CLIENT_ID=
META_CLIENT_SECRET=

# GOOGLE ADS CONFIGURATION
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Add Authorised JavaScript origins:
#    - https://ais-dev-fyuvmcb7wzz2bk75p4gm6r-195515573175.europe-west3.run.app
#    - https://ais-pre-fyuvmcb7wzz2bk75p4gm6r-195515573175.europe-west3.run.app
# 3. Add Authorised redirect URIs:
#    - https://ais-dev-fyuvmcb7wzz2bk75p4gm6r-195515573175.europe-west3.run.app/api/auth/callback/google
#    - https://ais-pre-fyuvmcb7wzz2bk75p4gm6r-195515573175.europe-west3.run.app/api/auth/callback/google
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_DEVELOPER_TOKEN=

# TIKTOK CONFIGURATION
# 1. Create an app at https://developers.tiktok.com/ 
# 2. Add "Marketing API" or "Commercial Content API" product.
# 3. Add Redirect URIs:
#    - https://ais-dev-fyuvmcb7wzz2bk75p4gm6r-195515573175.europe-west3.run.app/api/auth/callback/tiktok
#    - https://ais-pre-fyuvmcb7wzz2bk75p4gm6r-195515573175.europe-west3.run.app/api/auth/callback/tiktok
# 4. Use your App ID (long number) or Client ID (alphanumeric) as TIKTOK_CLIENT_ID.
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=

# SNAPCHAT CONFIGURATION
# Redirect URIs:
# - https://ais-dev-fyuvmcb7wzz2bk75p4gm6r-195515573175.europe-west3.run.app/api/auth/callback/snapchat
# - https://ais-pre-fyuvmcb7wzz2bk75p4gm6r-195515573175.europe-west3.run.app/api/auth/callback/snapchat
SNAPCHAT_CLIENT_ID=
SNAPCHAT_CLIENT_SECRET=

# Scraper Configuration
# Optional: Proxy URL for scraping (e.g. http://username:password@proxy-server:port)
SCRAPER_PROXY_URL=

# Queue Configuration
# Redis connection URL (e.g. redis://default:password@host:port)
# IMPORTANT: Use only the URL (starting with redis:// or rediss://). 
# Do NOT include CLI flags like '--tls' or '-u'.
REDIS_URL=
